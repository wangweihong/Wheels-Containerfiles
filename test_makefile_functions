#!/bin/bash

# Test script to verify get_component_dir function

# Define the same variables as in Makefile
COMPONENTS="cumesh flexGEMM o_voxel sageattn xformers fastvideo-kernel"

COMPONENT_DIRS="cumesh:3d/trellies/cumesh-py313-cu130-pt211 flexGEMM:3d/trellies/flexGEMM-py313-cu130-pt211 o_voxel:3d/trellies/o_voxel-py313-cu130-pt211 sageattn:sageattn-py313-cu130-pt211 xformers:xformers-cu124 fastvideo-kernel:fastvideo-kernel-py313"

# Function to mimic get_component_dir
function get_component_dir() {
    local comp="$1"
    local found=0
    
    for entry in $COMPONENT_DIRS; do
        if [[ "$entry" == "$comp:"* ]]; then
            echo "${entry#$comp:}"
            found=1
            break
        fi
    done
    
    if [[ $found -eq 0 ]]; then
        echo ""
    fi
}

# Test each component
echo "Testing get_component_dir function:"
echo "===================================="

for comp in $COMPONENTS; do
    dir=$(get_component_dir "$comp")
    if [[ -n "$dir" ]]; then
        echo "$comp -> $dir"
        # Check if directory exists
        if [[ -d "$dir" ]]; then
            echo "  ✓ Directory exists"
        else
            echo "  ✗ Directory does not exist"
        fi
    else
        echo "$comp -> ERROR: Component not found"
    fi
echo

done

echo "Testing complete."
